@model BTCPayServer.Plugins.Grin.Data.GrinInvoice
@{
    Layout = null;
    var amountGrin = Model.AmountNanogrin / 1_000_000_000m;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Payment Complete</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #1a1a2e;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .container {
            max-width: 420px;
            width: 100%;
            text-align: center;
        }
        .checkmark {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(0, 182, 52, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.5rem;
        }
        h1 { color: #00b634; margin-bottom: 0.5rem; font-size: 1.5rem; }
        .amount { font-size: 1.5rem; font-weight: bold; color: #fff; margin: 1rem 0; }
        .amount span { font-size: 0.9rem; color: #b0b0c0; }
        .detail { font-size: 0.85rem; color: #888; margin-top: 0.5rem; }
        .return-btn {
            display: inline-block;
            margin-top: 1.5rem;
            padding: 0.75rem 2rem;
            background: #f5c542;
            color: #1a1a2e;
            font-weight: 600;
            font-size: 1rem;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.2s;
        }
        .return-btn:hover { background: #e6b835; }
    </style>
</head>
<body>
    <div class="container">
        <img src="/Resources/img/grin-logo.png" alt="Grin" style="width:48px;height:48px;margin-bottom:1rem;" />
        <div class="checkmark">&#10003;</div>
        <h1>Payment Confirmed</h1>
        <div class="amount">@amountGrin <span>GRIN</span></div>
        <div class="detail">Confirmed with @Model.Confirmations confirmations</div>
        @if (Model.PaidAt.HasValue)
        {
            <div class="detail">Paid at @Model.PaidAt.Value.ToString("yyyy-MM-dd HH:mm UTC")</div>
        }
        @if (!string.IsNullOrEmpty(Model.RedirectUrl))
        {
            <a href="@Model.RedirectUrl" class="return-btn">Return to store</a>
            <script>
                // Auto-redirect after 5 seconds
                setTimeout(function() { window.location.href = "@Model.RedirectUrl"; }, 5000);
            </script>
            <div class="detail" style="margin-top:0.5rem;">Redirecting in 5 seconds...</div>
        }
    </div>
</body>
</html>
