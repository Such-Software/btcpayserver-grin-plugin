@model BTCPayServer.Plugins.Grin.Data.GrinInvoice
@{
    Layout = null;
    var amountGrin = Model.AmountNanogrin / 1_000_000_000m;
    var grinUsdPrice = (decimal)(ViewBag.GrinUsdPrice ?? 0m);
    var amountUsd = grinUsdPrice > 0 ? amountGrin * grinUsdPrice : 0m;
    var usdDisplay = amountUsd >= 0.01m ? $"~ ${amountUsd:F2} USD"
                   : amountUsd > 0 ? "< $0.01 USD"
                   : "";
    var statusText = Model.Status switch
    {
        BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.Pending => "Awaiting Payment",
        BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.AwaitingResponse => "Awaiting Response",
        BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.Broadcast => "Payment Broadcast — Awaiting Confirmations",
        _ => Model.Status.ToString()
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pay with Grin</title>
    <style>
        :root {
            --grin-yellow: #FFC107;
            --grin-dark: #1a1a2e;
            --grin-text: #e0e0e0;
            --grin-card: #16213e;
            --grin-border: #2a2a4a;
            --grin-success: #00b634;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--grin-dark);
            color: var(--grin-text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .checkout-container {
            max-width: 520px;
            width: 100%;
        }
        .checkout-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .checkout-header h1 {
            font-size: 1.5rem;
            color: var(--grin-yellow);
            margin-bottom: 0.25rem;
        }
        .checkout-amount {
            font-size: 2rem;
            font-weight: bold;
            color: #fff;
        }
        .checkout-amount span { font-size: 1rem; color: var(--grin-text); }
        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 0.5rem;
        }
        .status-pending { background: rgba(255, 193, 7, 0.2); color: var(--grin-yellow); }
        .status-broadcast { background: rgba(0, 182, 52, 0.2); color: var(--grin-success); }
        .card {
            background: var(--grin-card);
            border: 1px solid var(--grin-border);
            border-radius: 0.75rem;
            padding: 1.25rem;
            margin-bottom: 1rem;
        }
        .card h2 {
            font-size: 1rem;
            margin-bottom: 0.75rem;
            color: var(--grin-yellow);
        }
        .card p {
            font-size: 0.85rem;
            line-height: 1.5;
            color: #b0b0c0;
            margin-bottom: 0.75rem;
        }
        .qr-container {
            text-align: center;
            margin-bottom: 1rem;
        }
        .qr-container canvas {
            border-radius: 0.5rem;
            background: #fff;
            padding: 8px;
        }
        .qr-toggle {
            font-size: 0.75rem;
            color: var(--grin-yellow);
            cursor: pointer;
            margin-top: 0.5rem;
            display: inline-block;
        }
        .qr-toggle:hover { text-decoration: underline; }
        .slatepack-box {
            background: #0d1117;
            border: 1px solid var(--grin-border);
            border-radius: 0.5rem;
            padding: 0.75rem;
            font-family: 'Courier New', monospace;
            font-size: 0.7rem;
            word-break: break-all;
            max-height: 120px;
            overflow-y: auto;
            cursor: pointer;
        }
        .slatepack-box:hover { border-color: var(--grin-yellow); }
        .copy-hint {
            font-size: 0.7rem;
            color: #666;
            text-align: right;
            margin-top: 0.25rem;
        }
        textarea {
            width: 100%;
            background: #0d1117;
            border: 1px solid var(--grin-border);
            border-radius: 0.5rem;
            padding: 0.75rem;
            color: var(--grin-text);
            font-family: 'Courier New', monospace;
            font-size: 0.75rem;
            resize: vertical;
            min-height: 80px;
        }
        textarea:focus { outline: none; border-color: var(--grin-yellow); }
        .btn {
            display: inline-block;
            padding: 0.6rem 1.5rem;
            border: none;
            border-radius: 0.5rem;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.2s;
        }
        .btn:hover { opacity: 0.85; }
        .btn-primary {
            background: var(--grin-yellow);
            color: var(--grin-dark);
            width: 100%;
            margin-top: 0.75rem;
        }
        .error-banner {
            background: rgba(251, 56, 61, 0.15);
            border: 1px solid rgba(251, 56, 61, 0.3);
            color: #ff6b6b;
            padding: 0.75rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }
        .footer {
            text-align: center;
            margin-top: 1rem;
            font-size: 0.7rem;
            color: #555;
        }
    </style>
</head>
<body>
    <div class="checkout-container">
        <div class="checkout-header">
            <img src="/Resources/img/grin-logo.png" alt="Grin" style="width:48px;height:48px;margin-bottom:0.5rem;" />
            <h1>Pay with Grin</h1>
            <div class="checkout-amount">@amountGrin <span>GRIN</span></div>
            @if (!string.IsNullOrEmpty(usdDisplay))
            {
                <div style="font-size: 0.9rem; color: #b0b0c0;">@usdDisplay</div>
            }
            @if (Model.Status == BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.Broadcast)
            {
                <div class="status-badge status-broadcast">@statusText</div>
            }
            else
            {
                <div class="status-badge status-pending">@statusText</div>
            }
        </div>

        @if (TempData["Error"] is string error)
        {
            <div class="error-banner">@error</div>
        }

        @if (Model.Status == BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.Broadcast)
        {
            <div class="card">
                <h2>Payment Received</h2>
                <p>Your transaction has been broadcast to the network. Waiting for @ViewBag.MinConfirmations confirmations.</p>
                <p>Confirmations: <strong>@Model.Confirmations</strong></p>
            </div>
        }
        else
        {
            <div class="card">
                <h2>Slatepack Exchange</h2>
                <p>1. Scan the QR code or copy the invoice slatepack below and process it in your Grin wallet.</p>
                @if (!string.IsNullOrEmpty(Model.IssuedSlatepack))
                {
                    <div class="qr-container">
                        <div id="qr-code"></div>
                    </div>
                    <div class="slatepack-box" onclick="copyToClipboard(this)" title="Click to copy">
                        @Model.IssuedSlatepack
                    </div>
                    <div class="copy-hint">Click to copy</div>
                }

                <p style="margin-top: 1rem;">2. Paste your wallet's response slatepack below:</p>
                <form method="post" asp-action="SubmitSlatepack" asp-controller="GrinCheckout"
                      asp-route-storeId="@Model.StoreId" asp-route-invoiceId="@Model.Id">
                    <textarea name="responseSlatepack" placeholder="BEGINSLATEPACK. ... ENDSLATEPACK."></textarea>
                    <button type="submit" class="btn btn-primary">Submit Payment</button>
                </form>
            </div>
        }

        <div class="footer">
            Powered by BTCPay Server &bull; Grin Plugin
        </div>
    </div>

    <script src="~/js/qrcode.js" asp-append-version="true"></script>
    <script>
        // Generate QR code for slatepack
        (function() {
            var el = document.getElementById('qr-code');
            if (!el) return;
            var slatepack = document.querySelector('.slatepack-box');
            if (!slatepack) return;
            try {
                new QRCode(el, {
                    text: slatepack.innerText.trim(),
                    width: 200,
                    height: 200,
                    useSVG: true,
                    correctLevel: QRCode.CorrectLevel.L
                });
            } catch(e) {
                el.style.display = 'none';
            }
        })();

        function copyToClipboard(el) {
            navigator.clipboard.writeText(el.innerText.trim()).then(() => {
                const hint = el.nextElementSibling;
                if (hint) {
                    hint.textContent = 'Copied!';
                    setTimeout(() => hint.textContent = 'Click to copy', 2000);
                }
            });
        }

        // Poll for status updates
        (function poll() {
            const statusUrl = window.location.pathname + '/status';
            setInterval(async () => {
                try {
                    const resp = await fetch(statusUrl);
                    if (!resp.ok) return;
                    const data = await resp.json();
                    if (data.status === 'Broadcast' || data.status === 'Confirmed') {
                        window.location.reload();
                    }
                } catch (e) { /* ignore */ }
            }, 5000);
        })();
    </script>
</body>
</html>
