@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.Grin.Views
@model BTCPayServer.Plugins.Grin.GrinSettings
@{
    ViewData.SetActivePage(GrinNavPages.Settings, "Grin Settings");
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<div class="row">
    <div class="col-xxl-constrain col-xl-8">
        <form method="post" asp-action="Settings" asp-controller="UIGrin">
            <div class="form-group mb-3">
                <label asp-for="OwnerApiUrl" class="form-label">Wallet Owner API URL</label>
                <input asp-for="OwnerApiUrl" class="form-control" placeholder="http://127.0.0.1:3420" />
                <span class="text-muted small">The grin-wallet Owner API endpoint.</span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="WalletPassword" class="form-label">Wallet Password</label>
                <input asp-for="WalletPassword" class="form-control" type="password" />
                <span class="text-muted small">Password to unlock the grin-wallet.</span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="MinConfirmations" class="form-label">Minimum Confirmations</label>
                <input asp-for="MinConfirmations" class="form-control" type="number" min="1" max="100" />
                <span class="text-muted small">Number of confirmations before marking payment as complete (default: 10, ~10 minutes).</span>
            </div>
            <div class="form-check mb-4">
                <input asp-for="Enabled" class="form-check-input" type="checkbox" />
                <label asp-for="Enabled" class="form-check-label">Enable Grin Payments</label>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</div>
