@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.Grin.Services
@model BTCPayServer.Plugins.Grin.Data.GrinStoreSettings
@inject GrinSyncService SyncService
@{
    ViewData["Title"] = "Grin Settings";
    var storeId = Model.StoreId;
    var syncStatus = SyncService.GetCachedStatus();
}

<h2 class="mb-4">
    <img src="~/Resources/img/grin-logo.png" alt="" style="width:1.2em;height:1.2em;vertical-align:text-bottom;margin-right:0.25em;" />
    @ViewData["Title"]
</h2>

<partial name="_StatusMessage" />

@if (syncStatus != null)
{
    var statusClass = syncStatus.SyncState switch
    {
        "synced" => "enabled",
        "syncing" => "pending",
        _ => "disabled"
    };
    var statusText = syncStatus.SyncState switch
    {
        "synced" => $"Node synced (Height: {syncStatus.NodeHeight})",
        "syncing" => syncStatus.SyncPercent > 0
            ? $"Node syncing... {syncStatus.SyncPercent}% (Height: {syncStatus.NodeHeight})"
            : syncStatus.NodeHeight > 0
                ? $"Node syncing... (Height: {syncStatus.NodeHeight})"
                : "Node syncing...",
        "unreachable" => "Node unreachable",
        _ => "Not configured"
    };
    if (syncStatus.SyncState == "syncing" && !string.IsNullOrEmpty(syncStatus.NodeSyncStatus))
    {
        statusText += $" [{syncStatus.NodeSyncStatus}]";
    }
    <div class="d-flex align-items-center mb-4 p-3 bg-tile rounded">
        <span class="me-2 btcpay-status btcpay-status--@statusClass"></span>
        <span>@statusText</span>
        @if (!string.IsNullOrEmpty(syncStatus.Error))
        {
            <span class="ms-2 text-muted small">— @syncStatus.Error</span>
        }
    </div>
}

@{
    var balance = ViewBag.Balance as BTCPayServer.Plugins.Grin.UIGrinController.WalletBalanceView;
    // Format nanogrin → GRIN with trailing zeros trimmed. 1 GRIN = 1e9
    // nanogrin; display up to 9 decimal places, but strip trailing
    // zeros so common round numbers ("100" GRIN) don't render as
    // "100.000000000".
    string FormatGrin(long nanogrin)
    {
        var grin = nanogrin / 1_000_000_000m;
        var formatted = grin.ToString("0.#########");
        return formatted == "" ? "0" : formatted;
    }
}

@{
    var rateHealth = ViewBag.RateHealth as BTCPayServer.Plugins.Grin.Services.GrinRateHealthStatus;
}

@if (rateHealth != null)
{
    var (rateClass, rateText) = rateHealth.State switch
    {
        "fresh" => ("enabled", "Rate feed healthy"),
        "stale" => ("pending", "Rate feed degraded"),
        "failing" => ("disabled", "Rate feed FAILING"),
        "never_fetched" => ("pending", "Rate feed not yet fetched"),
        _ => ("disabled", "Rate feed: unknown")
    };
    string ageText = "";
    if (rateHealth.LastSuccess.HasValue)
    {
        var age = DateTimeOffset.UtcNow - rateHealth.LastSuccess.Value;
        if (age.TotalSeconds < 60)
            ageText = $"updated {(int)age.TotalSeconds}s ago";
        else if (age.TotalMinutes < 60)
            ageText = $"updated {(int)age.TotalMinutes}m ago";
        else
            ageText = $"updated {(int)age.TotalHours}h ago";
    }
    <div class="d-flex align-items-center mb-4 p-3 bg-tile rounded">
        <span class="me-2 btcpay-status btcpay-status--@rateClass"></span>
        <span>@rateText</span>
        @if (!string.IsNullOrEmpty(ageText))
        {
            <span class="ms-2 text-muted small">@ageText</span>
        }
        @if (rateHealth.ConsecutiveFailures > 0)
        {
            <span class="ms-2 text-muted small">— @rateHealth.ConsecutiveFailures consecutive failure@(rateHealth.ConsecutiveFailures == 1 ? "" : "s")</span>
        }
        @if (rateHealth.State == "failing" && !string.IsNullOrEmpty(rateHealth.LastError))
        {
            <span class="ms-2 text-muted small">— @rateHealth.LastError</span>
        }
    </div>

    @if (rateHealth.State == "failing")
    {
        <div class="alert alert-warning" role="alert">
            <strong>Heads-up:</strong> the GRIN/USDT rate feed from Gate.io
            is failing. New invoice creation will continue to work as long
            as the cached rate is still within its 10-minute validity
            window, but will start returning errors once that expires.
            Check that this server can reach <code>api.gateio.ws</code> and
            that the Gate.io API is up.
        </div>
    }
    else if (rateHealth.State == "stale")
    {
        <div class="alert alert-light" role="alert" style="border-color: #f0ad4e;">
            The rate feed has missed @rateHealth.ConsecutiveFailures recent refresh@(rateHealth.ConsecutiveFailures == 1 ? "" : "es"). Still serving cached data; will recover once Gate.io responds normally.
        </div>
    }
}

@if (balance != null)
{
    <div class="mb-4 p-3 bg-tile rounded">
        <h5 class="mb-3">
            <img src="~/Resources/img/grin-logo.png" alt="" style="width:1em;height:1em;vertical-align:text-bottom;margin-right:0.25em;" />
            Wallet Balance
        </h5>
        @if (!string.IsNullOrEmpty(balance.Error))
        {
            <div class="text-muted small">
                Could not fetch balance: <code>@balance.Error</code>
            </div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="text-muted small">Spendable</div>
                    <div class="fw-semibold" style="font-size:1.25em;">
                        @FormatGrin(balance.SpendableNanogrin) <span class="text-muted small">GRIN</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Awaiting confirmation</div>
                    <div class="fw-semibold">
                        @FormatGrin(balance.AwaitingNanogrin) <span class="text-muted small">GRIN</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Locked</div>
                    <div class="fw-semibold">
                        @FormatGrin(balance.LockedNanogrin) <span class="text-muted small">GRIN</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Total</div>
                    <div class="fw-semibold">
                        @FormatGrin(balance.TotalNanogrin) <span class="text-muted small">GRIN</span>
                    </div>
                </div>
            </div>
            @if (balance.LastConfirmedHeight > 0)
            {
                <div class="text-muted small mt-2">
                    As of block @balance.LastConfirmedHeight. Refresh the page to update.
                </div>
            }
        }
    </div>
}

<div class="row">
    <div class="col-xxl-constrain col-xl-8">
        <form method="post" asp-action="Settings" asp-controller="UIGrin" asp-route-storeId="@storeId">
            <div class="form-group mb-3">
                <label asp-for="OwnerApiUrl" class="form-label">Wallet Owner API URL</label>
                <input asp-for="OwnerApiUrl" class="form-control" placeholder="http://127.0.0.1:3420" />
                <span class="text-muted small">The grin-wallet Owner API endpoint for this store's wallet.</span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="WalletPassword" class="form-label">Wallet Password</label>
                <input asp-for="WalletPassword" class="form-control" type="password" value="@Model.WalletPassword" />
                <span class="text-muted small">Password to unlock the grin-wallet.</span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ApiSecret" class="form-label">API Secret</label>
                <input asp-for="ApiSecret" class="form-control" type="password" value="@Model.ApiSecret" />
                <span class="text-muted small">From .owner_api_secret file in the grin-wallet data directory.</span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="NodeApiUrl" class="form-label">Node API URL <span class="text-muted">(optional)</span></label>
                <input asp-for="NodeApiUrl" class="form-control" placeholder="http://127.0.0.1:3413" />
                <span class="text-muted small">
                    Grin node API endpoint for sync status monitoring. Leave empty if not running your own node.
                    The wallet connects to the node separately via <code>check_node_api_http_addr</code> in grin-wallet.toml.
                </span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="MinConfirmations" class="form-label">Minimum Confirmations</label>
                <input asp-for="MinConfirmations" class="form-control" type="number" min="1" max="100" />
                <span class="text-muted small">Number of confirmations before marking payment as complete (default: 10, ~10 minutes).</span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="WebhookUrl" class="form-label">Webhook URL <span class="text-muted">(optional)</span></label>
                <input asp-for="WebhookUrl" class="form-control" placeholder="https://api.example.com/hooks/payment/grin_grin" />
                <span class="text-muted small">
                    URL to receive payment notification webhooks (InvoicePaymentSettled, InvoiceExpired).
                    Leave empty to disable webhooks.
                </span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="WebhookSecret" class="form-label">Webhook Secret <span class="text-muted">(optional)</span></label>
                <input asp-for="WebhookSecret" class="form-control" type="password" value="@Model.WebhookSecret" />
                <span class="text-muted small">HMAC-SHA256 secret for signing webhook payloads (sent in <code>btcpay-sig</code> header).</span>
            </div>
            <div class="form-check mb-4">
                <input asp-for="Enabled" class="form-check-input" type="checkbox" />
                <label asp-for="Enabled" class="form-check-label">Enable Grin Payments</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>

        <form method="post" asp-action="TestConnection" asp-controller="UIGrin" asp-route-storeId="@storeId" class="mt-3">
            <button type="submit" class="btn btn-secondary">Test Connection</button>
        </form>

        <div class="alert alert-light mt-4" role="alert">
            <h6 class="alert-heading">Node Setup</h6>
            <p class="mb-1">
                The wallet connects to a Grin node via <code>check_node_api_http_addr</code> in
                <code>grin-wallet.toml</code>. You can run your own node or use a public node
                (<code>https://grincoin.org</code>, <code>https://grinnode.live:3413</code>).
            </p>
            <p class="mb-0 text-muted small">
                If running your own node, enter its API URL above to see detailed sync progress.
                See <a href="https://github.com/Such-Software/btcpayserver-grin-plugin/blob/master/SETUP.md" target="_blank" rel="noreferrer noopener">SETUP.md</a> for full setup instructions.
            </p>
        </div>
    </div>
</div>

@{
    var invoices = ViewBag.Invoices as List<BTCPayServer.Plugins.Grin.Data.GrinInvoice> ?? new List<BTCPayServer.Plugins.Grin.Data.GrinInvoice>();
}

@if (invoices.Any())
{
    <h3 class="mt-5 mb-3">Grin Invoices</h3>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Invoice ID</th>
                    <th>Amount (GRIN)</th>
                    <th>Status</th>
                    <th>Confirmations</th>
                    <th>Created</th>
                    <th>Paid</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in invoices)
                {
                    var amountGrin = inv.AmountNanogrin / 1_000_000_000m;
                    var badgeClass = inv.Status switch
                    {
                        BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.Confirmed => "bg-success",
                        BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.Broadcast => "bg-info",
                        BTCPayServer.Plugins.Grin.Data.GrinInvoiceStatus.Expired => "bg-secondary",
                        _ => "bg-warning text-dark"
                    };
                    <tr>
                        <td><code>@inv.Id</code></td>
                        <td>@amountGrin</td>
                        <td><span class="badge @badgeClass">@inv.Status</span></td>
                        <td>@inv.Confirmations</td>
                        <td>@inv.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(inv.PaidAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        <td>
                            <a asp-action="Checkout" asp-controller="GrinCheckout"
                               asp-route-storeId="@storeId" asp-route-invoiceId="@inv.Id"
                               class="btn btn-sm btn-outline-info">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
