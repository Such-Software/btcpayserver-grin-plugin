@using BTCPayServer
@using BTCPayServer.Client
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.Grin.Services
@model BTCPayServer.Components.MainNav.MainNavViewModel
@inject GrinService GrinService
@{
    var store = Context.GetStoreData();
}

@if (store != null)
{
    var settings = await GrinService.GetStoreSettings(store.Id);
    var isEnabled = settings?.Enabled == true;
    var isActive = ViewContext.RouteData.Values.TryGetValue("Controller", out var controller)
                   && controller?.ToString() == "UIGrin";
    <li class="nav-item" permission="@Policies.CanModifyStoreSettings">
        <a asp-area="" asp-controller="UIGrin" asp-action="Settings" asp-route-storeId="@store.Id"
           class="nav-link @(isActive ? "active" : "")" id="StoreNav-Grin">
            <span class="me-2 btcpay-status btcpay-status--@(isEnabled ? "enabled" : "pending")"></span>
            <img src="~/Resources/img/grin-logo.png" alt="" style="width:1.1em;height:1.1em;vertical-align:text-bottom;margin-right:0.25em;" />
            <span>Grin</span>
        </a>
    </li>
}
